{
  "name": "@lukasmurdock/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:build": "node src/generate-component-api-docs.mjs",
    "api:check": "node src/generate-component-api-docs.mjs --check",
    "check": "pnpm run api:check && pnpm run check:sections && pnpm run check:examples && pnpm run check:maturity && pnpm run check:imports && pnpm run check:guides && pnpm run check:demos",
    "dev": "vite",
    "build": "pnpm run api:build && node src/build-docs.mjs",
    "check:sections": "node src/check-component-doc-sections.mjs",
    "check:examples": "node src/check-component-doc-examples.mjs --strict",
    "audit:examples": "node src/check-component-doc-examples.mjs --report",
    "audit:examples:json": "node src/check-component-doc-examples.mjs --json",
    "check:maturity": "node src/check-component-doc-maturity.mjs",
    "check:imports": "node src/check-component-doc-imports.mjs",
    "check:guides": "node src/check-guide-docs.mjs",
    "check:demos": "node src/check-component-demos.mjs",
    "cf:dev": "pnpm run build && pnpm dlx wrangler dev --config wrangler.jsonc",
    "cf:deploy": "pnpm run build && pnpm dlx wrangler deploy --config wrangler.jsonc",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lukasmurdock/remix-ui-components": "workspace:*",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "7.1.12"
  }
}
