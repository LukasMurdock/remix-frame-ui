{
  "name": "@lukasmurdock/core",
  "description": "Core accessibility and form primitives for Remix Frame UI.",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukasmurdock/remix-frame-ui.git"
  },
  "homepage": "https://github.com/lukasmurdock/remix-frame-ui#readme",
  "bugs": {
    "url": "https://github.com/lukasmurdock/remix-frame-ui/issues"
  },
  "keywords": [
    "remix",
    "ui",
    "a11y",
    "forms",
    "components"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./overlay": {
      "types": "./dist/overlay.d.ts",
      "import": "./dist/overlay.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/overlay.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
