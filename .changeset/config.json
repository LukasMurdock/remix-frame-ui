{
  "$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
  "changelog": false,
  "commit": false,
  "fixed": [["@remix-frame-ui/core", "@remix-frame-ui/remix", "@remix-frame-ui/styles"]],
  "linked": [],
  "access": "public",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": ["@remix-frame-ui/docs"],
  "bumpVersionsWithWorkspaceProtocolOnly": false,
  "privatePackages": {
    "version": false,
    "tag": false
  },
  "snapshot": {
    "useCalculatedVersion": false,
    "prereleaseTemplate": "{tag}-{datetime}-{commit}"
  }
}
